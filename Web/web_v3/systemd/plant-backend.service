[Unit]
Description=Plant Monitoring FastAPI Backend
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
User=lucas
WorkingDirectory=/home/lucas/Plant-Monitoring-CPS/Web/web_v2/backend
EnvironmentFile=/home/lucas/Plant-Monitoring-CPS/Web/web_v2/backend/.env
ExecStart=/home/lucas/Plant-Monitoring-CPS/Web/web_v2/backend/env/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
