# Plant Monitoring CPS Backend v1.1.0-rpi-topic-v2
# Copy to .env and fill your real token. Do not commit .env.

INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_TOKEN=your_influx_token_here
INFLUX_ORG=DEV_TEAM
INFLUX_BUCKET=digital_twin_data

NODE_ID=BRASSICA_JUNCEA_01
NODE_TOPIC_ID=brassica_01
PLANT_NAME=Rau Cải Mầm (Brassica juncea)

# Add your frontend origins when needed.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.4.1:5173
